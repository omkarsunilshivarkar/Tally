# Port to run the Express backend on
PORT=5000

# Secret key used for signing JWT login tokens
JWT_SECRET=replace-with-a-secure-random-string-in-production

# Google Gemini API key (from Google AI Studio)
# Leave blank to run the app in simulated/mock mode for testing
GEMINI_API_KEY=

# Turso/SQLite Database Configuration
# Leave blank to use a local development file (local.db)
DATABASE_URL=
DATABASE_AUTH_TOKEN=
